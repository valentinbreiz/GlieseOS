<Project Sdk="Microsoft.NET.Sdk">

  <Sdk Name="Cosmos.Sdk" Version="3.0.38" />

  <PropertyGroup>
    <CosmosEnableKeyboard>false</CosmosEnableKeyboard>
    <CosmosEnableMouse>false</CosmosEnableMouse>
    <CosmosEnableNetwork>false</CosmosEnableNetwork>
    <CosmosEnablePci>false</CosmosEnablePci>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <CosmosKernelClass>GlieseOS.Kernel</CosmosKernelClass>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Cosmos.Kernel" Version="3.0.38" />
    <PackageReference Include="Cosmos.Kernel.System" Version="3.0.38" />
  </ItemGroup>

</Project>
